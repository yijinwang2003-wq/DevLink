# DevLink environment variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# Database
DATABASE_URL=postgresql+asyncpg://devlink:devlink@localhost:5432/devlink

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=replace_me_with_32_hex_chars

# OpenAI (required for AI matching features, optional for Phase 1-2)
OPENAI_API_KEY=sk-...

# Frontend (used by Vite)
VITE_API_URL=http://localhost:8000/api/v1
